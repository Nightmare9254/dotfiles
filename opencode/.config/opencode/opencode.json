{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://hub.ideosoftware.com/v1"
      },
      "models": {
        "claude-opus": {
          "name": "claude-opus",
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "claude-sonnet": {
          "name": "claude-sonnet",
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "gpt-codex": {
          "name": "gpt-codex",
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "gpt-chat": {
          "name": "gpt-chat",
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "gpt-mini": {
          "name": "gpt-mini",
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "ideo-auto (recommended)": {
          "name": "ideo-auto (recommended)",
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "oss-minimax": {
          "name": "oss-minimax",
          "modalities": { "input": ["text"], "output": ["text"] }
        }
      }
    },
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX (local MLX)",
      "options": {
        "baseURL": "http://127.0.0.1:2137/v1",
        "apiKey": "9254"
      },
      "models": {
        "Qwen3.5-27B-Claude-4.6-Opus-Distilled-MLX-4bit": {
          "name": "Qwen 3.5 Opus"
        },
        "Qwen3.6-35B-A3B-4bit": {
          "name": "Qwen 3.6"
        },
          "gpt-oss-20b-MXFP4-Q8": {
          "name": "GPT-OSS 20B"
        }
      }
    }
  },
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "better-auth": {
      "type": "remote",
      "url": "https://mcp.better-auth.com/mcp",
      "enabled": true
    }
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://hub.ideosoftware.com/v1"
      },
      "models": {
        "claude-opus": {
          "name": "claude-opus",
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "claude-sonnet": {
          "name": "claude-sonnet",
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "gpt-codex": {
          "name": "gpt-codex",
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "gpt-chat": {
          "name": "gpt-chat",
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "gpt-mini": {
          "name": "gpt-mini",
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "ideo-auto (recommended)": {
          "name": "ideo-auto (recommended)",
          "modalities": { "input": ["image", "text"], "output": ["text"] }
        },
        "oss-minimax": {
          "name": "oss-minimax",
          "modalities": { "input": ["text"], "output": ["text"] }
        }
      }
    }
  },
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "better-auth": {
      "type": "remote",
      "url": "https://mcp.better-auth.com/mcp",
      "enabled": true
    }
  }
}
